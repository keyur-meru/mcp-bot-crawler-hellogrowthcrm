{
  "name": "mcp-bot-crawler",
  "version": "1.0.0",
  "description": "MCP server that crawls, discovers, and analyzes bots (search engines, AI crawlers, scrapers) interacting with your website.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-bot-crawler": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "tsx src/index.ts",
    "test:coverage": "c8 --reporter=text --reporter=lcov node --test --import tsx test/*.test.ts",
    
    "typecheck": "tsc --noEmit",

    "lint": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "bot-detection",
    "crawler",
    "seo",
    "ai-crawlers",
    "gptbot",
    "claudebot",
    "googlebot",
    "robots.txt",
    "access-logs",
    "security"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@supabase/supabase-js": "^2.49.4",
    "dotenv": "^16.4.5",
    "undici": "^6.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "rimraf": "^5.0.10",
    "supabase": "^2.100.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.18"
  }
}
